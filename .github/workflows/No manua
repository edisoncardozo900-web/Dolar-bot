name: Bot Dolar Diario

on:
  schedule:
    - cron: '0 13 * * *'  # 13:00 UTC = 9am Chile
  workflow_dispatch:      # Esto activa el botón "Run workflow"

jobs:
  enviar_dolar:
    runs-on: ubuntu-latest
    steps:
      - name: Bajar el código
        uses: actions/checkout@v3
      
      - name: Instalar Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'
      
      - name: Instalar requests
        run: pip install requests
      
      - name: Correr el bot
        run: python Bot_dolar.py
